{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-tailwindcss"
  ],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply", 
          "layer",
          "variants",
          "responsive",
          "screen",
          "theme"
        ]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": [
          "theme",
          "min",
          "max",
          "clamp"
        ]
      }
    ],
    "declaration-block-no-redundant-longhand-properties": null,
    "alpha-value-notation": null
  },
  "ignoreFiles": [
    "dist/**/*",
    "build/**/*",
    ".next/**/*"
  ]
}
